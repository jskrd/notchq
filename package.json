{
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "db": "pnpm --filter @repo/db exec kysely --",
    "db:down": "pnpm --filter @repo/db exec kysely migrate rollback --all",
    "db:seed": "pnpm --filter @repo/db exec kysely seed run",
    "db:up": "pnpm --filter @repo/db exec kysely migrate latest",
    "dev": "pnpm -r --parallel run dev",
    "format": "prettier --write .",
    "lint": "pnpm -r run lint",
    "start": "pnpm -r --parallel run start",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": "^24",
    "pnpm": "^10"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "6.0.0",
    "@tsconfig/node24": "24.0.3",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.0.3",
    "dotenv": "17.2.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.0",
    "vitest": "4.0.16"
  }
}
