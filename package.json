{
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "check": "pnpm format:check && pnpm lint && pnpm knip && pnpm typecheck",
    "db": "pnpm --filter @repo/db exec kysely --",
    "db:down": "pnpm --filter @repo/db exec kysely migrate rollback --all",
    "db:seed": "pnpm --filter @repo/db exec kysely seed run",
    "db:up": "pnpm --filter @repo/db exec kysely migrate latest",
    "dev": "pnpm -r --parallel run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "lint": "pnpm -r run lint",
    "start": "pnpm -r --parallel run start",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": "^25",
    "pnpm": "^10"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "knip": "^5.88.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2"
    ]
  }
}
