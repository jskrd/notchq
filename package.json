{
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "db": "pnpm --filter @repo/db exec kysely --",
    "db:down": "pnpm --filter @repo/db exec kysely migrate rollback --all",
    "db:seed": "pnpm --filter @repo/db exec kysely seed run",
    "db:up": "pnpm --filter @repo/db exec kysely migrate latest",
    "dev": "pnpm -r --parallel run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -r run lint",
    "start": "pnpm -r --parallel run start",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": "^24",
    "pnpm": "^10"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@types/node": "^24.10.9",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
