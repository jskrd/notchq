{
  "name": "@repo/eslint-config",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@repo/typescript-config": "workspace:*",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "10.1.8",
    "typescript-eslint": "8.51.0"
  }
}
